	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:prefLabel xml:lang="en">Observation Domain</skos:prefLabel>
	<skos:narrower rdf:resource="https://mock.example.int/concept/22222222-2222-2222-2222-222222222222"/>
	<skos:narrower rdf:resource="https://mock.example.int/concept/33333333-3333-3333-3333-333333333333"/>
	<skos:inScheme rdf:resource="https://mock.example.int/concepts/concept_scheme/observation-domains"/>
	<skos:topConceptOf rdf:resource="https://mock.example.int/concepts/concept_scheme/observation-domains"/>
</rdf:Description>

<rdf:Description rdf:about="https://mock.example.int/concept/22222222-2222-2222-2222-222222222222">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:prefLabel xml:lang="en">Urban Infrastructure</skos:prefLabel>
	<dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-03</dct:modified>
