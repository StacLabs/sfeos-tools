<rdf:Description rdf:about="https://mock.example.int/concept/44444444-4444-4444-4444-444444444444">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<skos:prefLabel xml:lang="en">Road Networks</skos:prefLabel>
	<skos:definition xml:lang="en">Interconnected paved or unpaved paths designed for vehicular or pedestrian transit.</skos:definition>
	<dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-03</dct:modified>
	<skos:broader rdf:resource="https://mock.example.int/concept/22222222-2222-2222-2222-222222222222"/>
