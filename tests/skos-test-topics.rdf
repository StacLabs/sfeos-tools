<rdf:Description rdf:about="https://mock.example.int/concepts/concept_scheme/observation-domains">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
	<dct:title xml:lang="en">Mock Geo-Thesaurus</dct:title>
	<rdfs:label xml:lang="en">Observation Domains</rdfs:label>
	<dct:description xml:lang="en">A generic geospatial taxonomy for testing SKOS parsing and STAC Multi-Tenant Catalogs.</dct:description>
	<owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
	<dct:modified xml:lang="en">2026-03-03</dct:modified>
	<dct:rights xml:lang="en">Open Source Testing Data.</dct:rights>
	<skos:hasTopConcept rdf:resource="https://mock.example.int/concept/11111111-1111-1111-1111-111111111111"/>
</rdf:Description>

